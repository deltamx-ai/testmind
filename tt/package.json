{
  "name": "testmind",
  "version": "0.1.0",
  "description": "Pre-test code reviewer: compare Jira requirements vs code implementation",
  "type": "module",
  "bin": {
    "testmind": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "tsup": {
    "entry": ["src/index.ts"],
    "format": ["esm"],
    "target": "node18",
    "clean": true,
    "banner": {
      "js": "#!/usr/bin/env node"
    }
  }
}
